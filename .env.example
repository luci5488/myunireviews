# ─────────────────────────────────────────────────────────────────────────────
# MyUniReviews — Backend environment variables
#
# USAGE:
#   Development  → copy to .env and fill in values (already done for you)
#   Production   → SSH into server, copy this to .env and fill in every value
#
# Generate a JWT_SECRET:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost/myunireviews

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — server refuses to start without this
JWT_SECRET=REPLACE_WITH_output_of_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production frontend domain, no trailing slash
# Server refuses to start in production if this is not set
CORS_ORIGIN=https://myunireviews.com.au
FRONTEND_URL=https://myunireviews.com.au

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXX
MAIL_FROM=noreply@myunireviews.com.au

# ── Optional integrations (leave blank to disable) ───────────────────────────
ANTHROPIC_API_KEY=
SENTRY_DSN=

# ── Moderation ────────────────────────────────────────────────────────────────
AUTO_FLAG_THRESHOLD=3
LOG_LEVEL=info
