# ─────────────────────────────────────────────────────────────────────────────
# MyUniReviews — Frontend environment variables
#
# USAGE:
#   Development  → .env.local already configured for you
#   Production   → set these as environment variables in your hosting provider
#                  OR create .env.production on the server before running
#                  `npm run build`
# ─────────────────────────────────────────────────────────────────────────────

# URL of your backend API — no trailing slash
# This is inlined into the browser bundle, so it must be the public-facing URL
NEXT_PUBLIC_API_URL=https://api.myunireviews.com.au

# Optional: Sentry for frontend error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_PROJECT=myunireviews-web
